# Conexión a la BD LOCAL del bot (en la misma máquina, sin TLS)
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5432
LOCAL_PG_DATABASE=fudobi_boheme
LOCAL_PG_USER=fudobi_admin_boheme
LOCAL_PG_PASSWORD=__set_me__
LOCAL_PG_TABLE=quotes_output
LOCAL_PG_SCHEMA=public
# 'require' (encripta sin validar cert) | 'disable' | 'verify-full'
# Default: 'require'. helioho.st rechaza conexiones sin SSL.
LOCAL_PG_SSLMODE=require

# Supabase — destino de la ingesta
# El service_role key se obtiene en: Supabase Dashboard → Project Settings → API
# ⚠ NO commitees este archivo con valores reales.
SUPABASE_URL=https://__project_ref__.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__set_me__

# País al que pertenecen las filas de quotes_output (Peru / Colombia / etc.)
BOT_SYNC_COUNTRY=Peru
